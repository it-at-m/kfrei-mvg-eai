{
  "local-dev": {
    "Security": {
      "Auth": {
        "keycloak": {
          "Type": "OAuth2",
          "Grant Type": "Client Credentials",
          "Client ID": "{{CLIENT_ID}}",
          "Client Secret": "{{CLIENT_SECRET}}",
          "Scope": "roles",
          "Token URL": "{{TOKEN_URL}}"
        }
      }
    }
  }
}